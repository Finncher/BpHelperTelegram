{
  "CTk": {
    "color_scale": 1,
    "fg_color": ["#1a1a1a", "#1a1a1a"],
    "top_fg_color": ["#1f1f1f", "#1f1f1f"]
  },

  "CTkFont": {
    "family": "Segoe UI",
    "size": 13,
    "weight": "normal"
  },

  "CTkLabel": {
    "text_color": ["#ffffff", "#ffffff"],
    "fg_color": "transparent",
    "corner_radius": 0
  },

  "CTkFrame": {
    "fg_color": ["#1f1f1f", "#1f1f1f"],
    "corner_radius": 6,
    "border_width": 0,
    "border_color": ["transparent", "transparent"]
  },

  "CTkSwitch": {
    "button_color": ["#cc0000", "#cc0000"],
    "button_hover_color": ["#e60000", "#e60000"],
    "progress_color": ["#ff4d4d", "#ff4d4d"],
    "fg_color": ["#4a4a4a", "#4a4a4a"],
    "text_color": ["#ffffff", "#ffffff"],
    "text_color_disabled": ["#777777", "#777777"],
    "corner_radius": 6,
    "border_width": 1,
    "button_length": 8
  },

  "CTkSlider": {
    "button_color": ["#ff2e2e", "#ff2e2e"],
    "button_hover_color": ["#ff4d4d", "#ff4d4d"],
    "progress_color": ["#b00000", "#b00000"],
    "fg_color": ["#3a3a3a", "#3a3a3a"],
    "border_color": ["#555555", "#555555"],
    "border_width": 6,
    "corner_radius": 10
  },

  "CTkButton": {
    "fg_color": ["#b00000", "#b00000"],
    "hover_color": ["#d00000", "#d00000"],
    "text_color": ["#ffffff", "#ffffff"],
    "text_color_disabled": ["#777777", "#777777"],
    "corner_radius": 6,
    "border_width": 0,
    "border_color": ["#ffffff", "#3a3a3a"]
  },

  "CTkCheckBox": {
    "fg_color": ["#3a3a3a", "#3a3a3a"],
    "hover_color": ["#4a4a4a", "#4a4a4a"],
    "border_color": ["#ff2e2e", "#ff2e2e"],
    "checkmark_color": ["#ff2e2e", "#ff2e2e"],
    "text_color": ["#ffffff", "#ffffff"],
    "text_color_disabled": ["#777777", "#777777"],
    "corner_radius": 4,
    "border_width": 2
  },

  "CTkEntry": {
    "fg_color": ["#3a3a3a", "#3a3a3a"],
    "border_color": ["#ff2e2e", "#ff2e2e"],
    "text_color": ["#ffffff", "#ffffff"],
